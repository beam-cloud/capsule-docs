            "pages": [
              "concepts/sessions-and-channels",
              "concepts/collections-and-data",
              "concepts/pages-and-ui",
              "concepts/tasks-and-scheduling",
              "concepts/integrations-secrets-and-filesystems",
              "concepts/app-styles"
            ]
          },
          {
            "group": "Build Guides",
            "pages": [
              "tutorials/first-chat-app",
              "tutorials/collections-and-scopes",
              "tutorials/data-handlers-and-pages",
              "tutorials/react-pages-and-theme",
