{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "linden",
  "name": "Capsule",
  "colors": {
    "primary": "#2563EB",
    "light": "#8590E8",
    "dark": "#8590E8"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "light": "#FAF9F6",
      "dark": "#252321"
    }
  },
  "logo": {
    "light": "/logo-light.svg",
    "dark": "/logo-dark.svg"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "family": "DM Sans",
    "heading": {
      "family": "DM Sans",
      "weight": 600
    },
    "body": {
      "family": "DM Sans",
      "weight": 450
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Start Here",
            "pages": ["index", "installation", "quickstart", "troubleshooting"]
          },
          {
            "group": "Build Apps",
            "pages": [
              "build/first-chat-app",
              "build/add-data-and-state",
              "build/add-pages",
              "build/connect-services",
              "build/background-work",
              "build/deploy-an-app"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/chat-and-sessions",
              "features/pages",
              "features/collections",
              "features/integrations",
              "features/secrets",
              "features/filesystems",
              "features/tasks-and-schedules",
              "features/channels",
              "features/workflows",
              "features/custom-react-pages",
              "features/themes"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/why-capsule",
              "concepts/app-model-and-runtime",
              "concepts/auth-and-scopes",
              "concepts/app-styles"
            ]
          },
          {
            "group": "Updates",
            "pages": [
              "changelog",
              "sdk-runtime-versions"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Python App API",
            "pages": [
              "reference/app-api",
              "reference/decorators",
              "reference/session-and-request-context",
              "reference/collections-and-settings",
              "reference/ui-and-pages",
              "reference/workflows",
              "reference/channels-integrations-and-secrets",
              "reference/client",
              "reference/image-theme-and-deployment"
            ]
          },
          {
            "group": "CLI",
            "pages": ["reference/cli"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/beam-cloud/capsule",
          "icon": "github"
        }
      ]
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Repository",
      "href": "https://github.com/beam-cloud/capsule"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/beam-cloud/capsule"
    }
  }
}
